# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to the project root, or absolute).
DATABASE_URL="file:./data/cnam-vms.db"

# AES-256/SQLCipher encryption key for the SQLite database.
# Generate a strong key: openssl rand -base64 32
# If set, the database is created/opened encrypted from first use.
# IMPORTANT: back this up securely — losing it means losing the database.
DB_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# ─── Auth.js / NextAuth ────────────────────────────────────────────────────────
# JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Public-facing URL of this deployment (used for password-reset links etc.).
# Set to your Cloudflare tunnel URL, e.g. http://your-name.trycloudflare.com
# Do NOT include a trailing slash.
AUTH_URL="http://your-tunnel.trycloudflare.com"

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Used for 2FA one-time password (OTP) and password-reset emails.
# Leave EMAIL_SERVER_HOST unset (commented out) to disable SMTP and instead
# have all email content printed to the server log (pm2 logs) — useful during
# initial setup when SMTP is not yet available.
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="noreply@example.com"
EMAIL_SERVER_PASSWORD="your-smtp-password"
EMAIL_FROM="CNAM VMS <noreply@example.com>"

# TLS / STARTTLS options (all optional, defaults shown):
# EMAIL_SERVER_SECURE="false"            # true  → implicit TLS on connect (port 465 style)
# EMAIL_SERVER_REQUIRE_TLS="false"       # true  → force STARTTLS upgrade (port 587)
# EMAIL_TLS_REJECT_UNAUTHORIZED="true"   # false → accept self-signed certificates

# ─── Bootstrap / Seeding ──────────────────────────────────────────────────────
# Email address of the initial root/superadmin user.
ROOT_USER_EMAIL="admin@example.com"
# Display name for the root user (used when seeding).
ROOT_USER_NAME="Root Admin"

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR="/var/uploads/cnam-vms"
UPLOAD_MAX_SIZE_MB="10"

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for next start / PM2. Defaults to 3001 if not set.
PORT="3001"
