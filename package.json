{
  "name": "cnam-vms",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && NODE_OPTIONS=--max-old-space-size=512 next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:set-initial-password": "ts-node --project tsconfig.seed.json scripts/set-initial-password.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
