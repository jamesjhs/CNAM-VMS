{
  "name": "cnam-vms",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${PORT:-3001}",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=512 next build",
    "postbuild": "node scripts/postbuild.js",
    "start": "cross-env PORT=${PORT:-3001} node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:seed": "ts-node --project tsconfig.seed.json scripts/seed.ts",
    "db:set-initial-password": "ts-node --project tsconfig.seed.json scripts/set-initial-password.ts",
    "db:reset-password": "ts-node --project tsconfig.seed.json scripts/reset-password.ts",
    "db:create-user": "ts-node --project tsconfig.seed.json scripts/create-user.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "postcss": "^8.5.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
