# next-auth@5.0.0-beta declares peerOptional nodemailer@^7, but the project
# requires nodemailer@^8 (which fixes SMTP injection CVEs GHSA-c7w3-x93f-qmm8
# and GHSA-vvjj-xcjg-gr5g). legacy-peer-deps allows npm to install the newer
# version without the strict peer-resolution error.
legacy-peer-deps=true
